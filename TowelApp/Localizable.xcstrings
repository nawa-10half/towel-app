        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 초대 코드는 무효화되고 새 코드가 생성됩니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le code d'invitation actuel sera invalidé et un nouveau code sera généré."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der aktuelle Einladungscode wird ungültig und ein neuer Code wird generiert."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El código de invitación actual se invalidará y se generará un nuevo código."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O código de convite atual será invalidado e um novo código será gerado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Текущий код приглашения станет недействительным, и будет сгенерирован новый код."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il codice invito attuale verrà invalidato e ne verrà generato uno nuovo."
          }
        }
      }
    },
    "交換期限を過ぎたタオルについてもリマインドします": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Also reminds you about towels past their exchange deadline"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "也会提醒已过更换期限的毛巾"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "교환 기한이 지난 수건에 대해서도 알려줍니다"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rappelle également les serviettes dont la date de changement est dépassée"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erinnert auch an Handtücher, deren Wechselfrist überschritten ist"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "También te recuerda las toallas cuyo plazo de cambio ha pasado"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Também lembra sobre toalhas que já passaram do prazo de troca"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Также напоминает о полотенцах с истекшим сроком замены"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ricorda anche gli asciugamani con scadenza di sostituzione superata"
          }
        }
      }
    },
    "交換時期が近づくとリマインダーが届きます": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You'll receive a reminder when exchange time is approaching"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "更换时间快到时会收到提醒"
