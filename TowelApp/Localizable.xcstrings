    "交換のタイミングを\n見える化": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Visualize\nExchange Timing"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将更换时机\n可视化"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "교환 타이밍을\n한눈에"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Visualisez\nle moment du changement"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wechselzeitpunkt\nauf einen Blick"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Visualiza\nel momento del cambio"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Visualize\no Momento da Troca"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Время замены\nнаглядно"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Visualizza\nil momento della sostituzione"
          }
        }
      }
    },
    "タオルごとに交換間隔を設定すると、\n余裕あり・もうすぐ・超過をひと目で把握できます。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set exchange intervals for each towel,\nand see at a glance if there's plenty of time, coming soon, or overdue."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为每条毛巾设置更换间隔，\n一目了然地了解是否充裕、即将到期或已过期。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "수건별로 교환 간격을 설정하면\n여유·곧 교환·초과를 한눈에 파악할 수 있습니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Définissez l'intervalle de changement pour chaque serviette\net voyez d'un coup d'œil si c'est OK, bientôt ou en retard."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Legen Sie das Wechselintervall für jedes Handtuch fest\nund sehen Sie auf einen Blick, ob noch Zeit ist, es bald soweit ist oder überfällig."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Establece intervalos de cambio para cada toalla\ny ve de un vistazo si hay tiempo, es pronto o está vencida."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Defina intervalos de troca para cada toalha\ne veja de relance se há tempo, está próximo ou atrasado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Задайте интервал замены для каждого полотенца\nи сразу видьте: есть время, скоро или просрочено."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Imposta l'intervallo di sostituzione per ogni asciugamano\ne vedi a colpo d'occhio se c'è tempo, è imminente o scaduto."
          }
        }
      }
    },
    "AIがタオルの\n状態を診断": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "AI Diagnoses\nTowel Condition"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "AI诊断\n毛巾状态"
          }
        },
