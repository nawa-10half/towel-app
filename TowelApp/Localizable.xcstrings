          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie erhalten eine Erinnerung, wenn der Wechselzeitpunkt naht"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Recibirás un recordatorio cuando se acerque el momento del cambio"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você receberá um lembrete quando o momento da troca estiver próximo"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
