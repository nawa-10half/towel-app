          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All exchange and diagnosis history will also be deleted. This action cannot be undone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todo el historial de cambios y diagnósticos también se eliminará. Esta acción no se puede deshacer."
