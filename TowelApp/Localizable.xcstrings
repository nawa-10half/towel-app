    "機種変更や再インストール時に必要です。\n忘れるとデータを復元できません。" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wird beim Gerätewechsel oder einer Neuinstallation benötigt.\nBei Verlust können die Daten nicht wiederhergestellt werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Required when changing devices or reinstalling.\nIf forgotten, data cannot be restored."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Necesario al cambiar de dispositivo o reinstalar.\nSi lo olvidas, los datos no podrán restaurarse."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nécessaire lors d'un changement d'appareil ou d'une réinstallation.\nSi vous l'oubliez, vos données ne pourront pas être restaurées."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Necessario in caso di cambio dispositivo o reinstallazione.\nSe dimenticato, i dati non potranno essere ripristinati."
          }
        },
        "ko" : {
